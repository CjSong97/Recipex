# Copy this file to .env.local and fill in your key.
# .env.local is gitignored — never commit real keys.

# Optional. Powers the second recipe source (lib/spoonacular.js) alongside
# TheMealDB. Get a free key (no credit card) at:
#   https://spoonacular.com/food-api/console
# Free tier: 50 points/day. If this is unset, the app runs fine on
# TheMealDB alone — Spoonacular results just won't appear.
SPOONACULAR_API_KEY=
